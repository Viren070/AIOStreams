{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/refs/heads/main/schemas/config.json",
  "release-type": "simple",
  "bump-minor-pre-major": true,
  "include-v-in-tag": true,
  "packages": {
    ".": {
      "release-type": "node",
      "include-component-in-tag": false,
      "exclude-paths": [
        ".env.sample",
        ".gitignore",
        ".release-please-manifest.json",
        "compose.yaml",
        "release-please-config.json"
      ],
      "pull-request-title-pattern": "chore: release ${version}"
    },
    "packages/seanime-extension": {
      "release-type": "node",
      "include-component-in-tag": true,
      "include-v-in-tag": true,
      "skip-github-release": true,
      "pull-request-title-pattern": "chore: release seanime-extension ${version}",
      "extra-files": [
        {
          "type": "json",
          "path": "packages/seanime-extension/src/extensions/aiostreams-plugin/manifest.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "packages/seanime-extension/src/extensions/aiostreams-torrent-provider/manifest.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}